# Copy to `.env` for local use, or pass the same keys via `docker-compose` / your shell.
# This app does not include `dotenv-rails`; export vars yourself or use Compose `env_file`.

# Required whenever the API issues or verifies JWTs (register, login, authenticated routes).
JWT_SECRET=change_me_use_a_long_random_string

# Optional: password for `db:seed` user seed@example.com (default is password123).
# SEED_USER_PASSWORD=password123

# Optional: full Postgres URL. When set, Rails merges it over `config/database.yml`.
# Typical for Docker (host is often the compose service name, e.g. `db`):
# DATABASE_URL=postgres://postgres:postgres@db:5432/taskflow_nitin_pasricha_development

# Optional: common names for the official Postgres image (use in compose for the DB service).
# Point `DATABASE_URL` at this instance from the API service.
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=taskflow_nitin_pasricha_development

# Production only — `config/database.yml` reads this for the primary DB password when not using DATABASE_URL.
# TASKFLOW_NITIN_PASRICHA_DATABASE_PASSWORD=

# Production only — decrypt `config/credentials.yml.enc` (e.g. Kamal / Docker deploy).
# RAILS_MASTER_KEY=
