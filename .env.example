# Copy to `.env` for local use. Docker Compose reads `.env` for variable substitution
# (and passes interpolated values into containers when you use ${VAR} in docker-compose.yml).

# --- Required for JWT (local server and Docker web service) ---
JWT_SECRET=change_me_use_a_long_random_string

# --- Docker Compose (`docker compose up`) ---
# Required for production Rails in the `web` image (same value as `config/master.key` on one line):
# RAILS_MASTER_KEY=

# Postgres (defaults match docker-compose.yml; override if you like)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_PORT=5432
# WEB_PORT=3000

# Optional: password for `db:seed` user seed@example.com (default password123).
# SEED_USER_PASSWORD=password123

# --- Local dev without Docker (optional) ---
# When set, Rails merges over `config/database.yml`:
# DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/taskflow_nitin_pasricha_development

# --- Kamal / bare-metal production (when not using DATABASE_URL for everything) ---
# TASKFLOW_NITIN_PASRICHA_DATABASE_PASSWORD=
